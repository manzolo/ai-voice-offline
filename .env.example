# ========================================
# AI Voice Offline - Environment Configuration
# ========================================
#
# This file serves as a template for environment configuration.
# Copy this file to .env to configure the conversation service.
#
# The setup commands will create this file automatically.
# ========================================

# ========================================
# Language & Voice Configuration
# ========================================

# Default language for TTS and conversation
DEFAULT_LANGUAGE=en

# Default speaker for TTS (when not using voice cloning)
DEFAULT_SPEAKER=male

# ========================================
# AI Model Configuration
# ========================================

# Whisper STT Model
WHISPER_MODEL=large-v3

# Ollama LLM Model (optimized for 8GB VRAM)
OLLAMA_MODEL=tinyllama:1.1b

# ========================================
# CORS Configuration
# ========================================

# CORS settings for TTS service
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# CORS settings for Whisper service
ALLOW_ORIGINS=["*"]

# ========================================
# Service Ports
# ========================================

# TTS Service (Text-to-Speech)
TTS_PORT=9876

# STT Service (Speech-to-Text / Whisper)
STT_PORT=10300

# Ollama Service (LLM)
OLLAMA_PORT=11434

# Conversation Service (Orchestrator)
CONVERSATION_PORT=9877

# Web Interface (Conversation UI)
WEB_CONVERSATION_PORT=8080

# ========================================
# GPU Configuration
# (Only used in GPU mode)
# ========================================

CUDA_VISIBLE_DEVICES=0

# ========================================
# Voice Cloning Configuration
# ========================================

# Voice profile for conversation mode
# Place WAV files in voice-profiles/{VOICE_PROFILE}/
VOICE_PROFILE=default

# ========================================
# Conversation Service Timeouts (seconds)
# ========================================

# STT timeout (increase if model loading takes long on first request)
# Default: 120 seconds (allows time for model loading)
STT_TIMEOUT=120

# Ollama timeout (increase for complex/long responses)
# Default: 90 seconds
OLLAMA_TIMEOUT=90

# TTS timeout (increase for long text or slow voice cloning)
# Default: 180 seconds (3 minutes for voice cloning)
TTS_TIMEOUT=180

# ========================================
# System Configuration
# ========================================

# User Configuration
PUID=1000
PGID=1000
TZ=UTC
